# --- LLM provider selection --------------------------------------------------
# The app talks to the LLM through LiteLLM, so `LLM_MODEL` is the ONLY thing
# you change to switch providers. Only Anthropic supported for now. Example:
#   Anthropic   -> claude-opus-4-8  (needs ANTHROPIC_API_KEY)
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

# --- Embeddings (for vector similarity) -------------------------------------
# "local"  -> sentence-transformers, no API key, runs offline (default)
# "hash"   -> deterministic offline fallback, no model download (for CI/tests)
EMBEDDING_PROVIDER=local

# --- Data / storage paths ---------------------------------------------------
DATASET_PATH=data/Incident_Investigation_dataset.xlsx
SQLITE_PATH=data/incident.db
CHROMA_PATH=data/chroma

# --- Agent behaviour --------------------------------------------------------
MAX_TOOL_ITERATIONS=8